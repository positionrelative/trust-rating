<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Trustindex Reviews{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⭐</text></svg>">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <header class="site-header">
            <nav class="site-nav">
                <a class="site-nav__brand" href="{{ path('review_index') }}">Trustindex Reviews</a>
                <div class="site-nav__links">
                    <a href="{{ path('review_index') }}">{{ 'nav.reviews'|trans }}</a>
                    <a href="{{ path('review_new') }}">{{ 'nav.write_review'|trans }}</a>
                    <a href="{{ path('company_index') }}">{{ 'nav.companies'|trans }}</a>
                </div>
            </nav>
        </header>

        <main class="page">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash flash--{{ label }}" role="status">{{ message|trans }}</div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>
    </body>
</html>
